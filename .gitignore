# Project-specific artifacts (created by users, not part of framework)
.specify/memory/constitution.md
.specify/context.json
.specify/active-feature
.specify/evals/

# Test directories (regenerate using TEST-GUIDE.md)
test-vanilla-*/
test-skills-*/
test-vanilla/
test-skills/

# Spec-kit templates (reference only, not part of bundle)
spec-kit-templates/

# Old comparison reports (consolidated into TEST-REPORT.md)
COMPARISON-REPORT.md
COMPARISON-REPORT-V2.md

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
ENV/

# Node (if used in testing)
node_modules/

# Logs
*.log
.mcp.json
.tessl/*
!.tessl/plugins/
# Local plugin development uses `tessl install file:./tiles/intent-integrity-kit`
# (see CONTRIBUTING.md). The install populates `.tessl/plugins/tessl-labs/...`
# from the local source tree; the rule below keeps that install output out of git.
.tessl/plugins/*
tessl.json

# Tessl-installed skill symlinks (generated by tessl install)
.claude/skills/tessl__*
.claude/skills/tessl:*
.codex/skills/tessl__*
.codex/skills/tessl:*
.gemini/skills/tessl__*
.gemini/skills/tessl:*
.opencode/skills/tessl__*
.opencode/skills/tessl:*

# npm artifacts (created by CI/tests, not project dependencies)
package.json
package-lock.json
node_modules/
tests/context.json
tests/dashboard/package.json
tests/dashboard/package-lock.json
tests/dashboard/node_modules/
