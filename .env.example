# Configure as GitHub Actions repository secrets:
#   https://github.com/intent-integrity-chain/kit/settings/secrets/actions

# OpenAI billing account for the gh-aw Codex policy reviewer.
# Required by .github/workflows/review-openai.lock.yml. The reviewer
# accepts either OPENAI_API_KEY or CODEX_API_KEY — set whichever
# matches your existing repo conventions.
# Generate at https://platform.openai.com/api-keys
OPENAI_API_KEY=
CODEX_API_KEY=

# Anthropic billing account for the gh-aw Claude Code policy reviewer.
# Required by .github/workflows/review-anthropic.lock.yml.
# Generate at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Tessl API token used by the workflow's `tessl install` step
# to fetch the `jbaruch/coding-policy` tile at runtime.
# Required by both reviewer workflows.
# Generate at https://tessl.io/account/api-keys
TESSL_TOKEN=
